samples/.codeatlas/index-*.db
samples/.codeatlas/current-db.json
samples/.codeatlas/mcp-runtime-stats.json

# Logs
*.log

# Local tooling/cache
.npm-cache/
.tools/

# Temporary local scripts and debug artifacts
_parse_check.ps1
indexer/stats

# Eval harness runtime outputs (regenerated per run; fixtures themselves are tracked)
eval/fixtures/*.eval.json
