# Dependencies
node_modules/

# Build output
dist/
target/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# SQLite WAL/journal (transient, never commit)
*.db-journal
*.db-wal
*.db-shm

