; Lua call-relation extraction rules for Milestone 18.
; Patterns:
;   func()              - unqualified
;   obj.method()        - member_access (dot)
;   obj:method()        - this_pointer_access (colon, self-call)
;   Module.func()       - member_access

; unqualified call: func(args)
(function_call
  name: (identifier) @callee
  arguments: (arguments) @args) @call
{
  node @call.event
  attr (@call.event) relation_kind = "call"
  attr (@call.event) call_kind = "unqualified"
  attr (@call.event) target_name = (source-text @callee)
  attr (@call.event) argument_count = (named-child-count @args)
  attr (@call.event) line = (plus (start-row @call) 1)
}

; dot member access: obj.method(args)
(function_call
  name: (dot_index_expression
    table: (identifier) @receiver
    field: (identifier) @callee)
  arguments: (arguments) @args) @call
{
  node @call.event
  attr (@call.event) relation_kind = "call"
  attr (@call.event) call_kind = "member_access"
  attr (@call.event) target_name = (source-text @callee)
  attr (@call.event) argument_count = (named-child-count @args)
  attr (@call.event) receiver = (source-text @receiver)
  attr (@call.event) line = (plus (start-row @call) 1)
}

; colon method call: obj:method(args)
(function_call
  name: (method_index_expression
    table: (identifier) @receiver
    method: (identifier) @callee)
  arguments: (arguments) @args) @call
{
  node @call.event
  attr (@call.event) relation_kind = "call"
  attr (@call.event) call_kind = "this_pointer_access"
  attr (@call.event) target_name = (source-text @callee)
  attr (@call.event) argument_count = (named-child-count @args)
  attr (@call.event) receiver = (source-text @receiver)
  attr (@call.event) line = (plus (start-row @call) 1)
}
